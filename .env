# Database Configuration - Render PostgreSQL
# Database Name: jobnect_db
# 
# CRITICAL: This .env file is for LOCAL TESTING ONLY
# For Render deployment, you MUST add DATABASE_URL in Render Dashboard:
# 
# Steps:
# 1. Go to https://dashboard.render.com
# 2. Click your PostgreSQL database (jobnect_db)
# 3. Copy the "Internal Database URL" (starts with postgresql://)
# 4. Go to your backend service → Environment tab
# 5. Add: DATABASE_URL = [paste the URL you copied]
# 6. Save - Render will auto-redeploy
#
# Example format: postgresql://jobnect_db_user:password@dpg-xxxxx.oregon-postgres.render.com/jobnect_db
DATABASE_URL=postgresql://localhost:5432/jobnect_db

# Domain Configuration
